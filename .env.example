# Google Maps Platform
# Enable: Map Tiles API, Places API (New), Geocoding API
# https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_API_KEY=
# Optional — if omitted, a session is created automatically from the API key
VITE_GOOGLE_MAPS_SESSION_TOKEN=

# Cesium Ion — terrain
# https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=

# OAuth — Google Sign-In
# https://console.cloud.google.com/apis/credentials
# Create OAuth Client ID (Web application)
# Authorized JavaScript origins:
#   http://localhost:5173
#   https://andrewtyrs.github.io
VITE_GOOGLE_OAUTH_CLIENT_ID=

# OAuth — Meta (Facebook) Login
# https://developers.facebook.com/apps/
# Facebook Login → Settings:
#   Site URL: https://andrewtyrs.github.io/Maptrip/
#   App Domains: andrewtyrs.github.io
VITE_META_APP_ID=

# GitHub Pages (Settings → Secrets and variables → Actions):
#   VITE_GOOGLE_OAUTH_CLIENT_ID
#   VITE_META_APP_ID

# Google Maps Platform — Map Tiles API
# https://developers.google.com/maps/documentation/tile
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_MAPS_SESSION_TOKEN=

# Yandex Maps — for RU/CIS regions
VITE_YANDEX_MAPS_API_KEY=

# Cesium Ion — terrain & fallback satellite imagery
# https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=

# OAuth — Google Sign-In
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_OAUTH_CLIENT_ID=

# OAuth — Meta (Facebook) Login
# https://developers.facebook.com/apps/
VITE_META_APP_ID=
